{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/glab-groups/config.schema.json",
  "type": "object",
  "required": [
    "kind",
    "version"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "glab-groups/defaults",
        "glab-groups/namespaces",
        "glab-groups/projects",
        "glab-groups/project-overrides",
        "glab-groups/project-exclusions"
      ]
    },
    "version": {
      "type": "integer",
      "const": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "glab-groups/defaults"
          }
        }
      },
      "then": {
        "required": [
          "defaults"
        ],
        "properties": {
          "defaults": {
            "$ref": "#/$defs/policy"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "glab-groups/namespaces"
          }
        }
      },
      "then": {
        "required": [
          "namespaces"
        ],
        "properties": {
          "namespaces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/namespace"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "glab-groups/projects"
          }
        }
      },
      "then": {
        "required": [
          "projects"
        ],
        "properties": {
          "projects": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/project"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "glab-groups/project-overrides"
          }
        }
      },
      "then": {
        "required": [
          "projects"
        ],
        "properties": {
          "projects": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/projectOverride"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "glab-groups/project-exclusions"
          }
        }
      },
      "then": {
        "required": [
          "projects"
        ],
        "properties": {
          "projects": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/projectExclusion"
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "httpsUrl": {
      "type": "string",
      "pattern": "^https://[A-Za-z0-9.-]+(:[0-9]+)?(/[^?#]+)?$"
    },
    "namespacePath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "projectPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*/[A-Za-z0-9][A-Za-z0-9._-]*(/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "pathSegment": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "refSpec": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9A-Za-z._/-]+$"
        },
        {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string",
              "pattern": "^[0-9A-Za-z._/-]+$"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "policy": {
      "type": "object",
      "properties": {
        "allow_blob_rewrite": {
          "type": "boolean"
        },
        "additional_branches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refSpec"
          }
        },
        "additional_tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refSpec"
          }
        },
        "batch_size": {
          "type": "integer",
          "minimum": 1,
          "default": 25
        },
        "force_lfs": {
          "type": "boolean"
        },
        "git_timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "gitlab_source_include_subgroups": {
          "type": "boolean",
          "default": false
        },
        "max_blob_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 104857600
        },
        "mirror_pristine_tar": {
          "type": "boolean",
          "default": true
        },
        "read_retry_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "read_retry_backoff_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "retry_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "retry_backoff_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "size_limit_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9663676416
        }
      }
    },
    "namespace": {
      "allOf": [
        {
          "$ref": "#/$defs/policy"
        },
        {
          "type": "object",
          "required": [
            "name",
            "source_group_url",
            "target_namespace_path"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "source_group_url": {
              "$ref": "#/$defs/httpsUrl"
            },
            "target_owner_path": {
              "$ref": "#/$defs/namespacePath"
            },
            "target_namespace_path": {
              "$ref": "#/$defs/namespacePath"
            }
          }
        }
      ]
    },
    "project": {
      "allOf": [
        {
          "$ref": "#/$defs/policy"
        },
        {
          "type": "object",
          "required": [
            "name",
            "source_project_url",
            "target_group_path"
          ],
          "properties": {
            "name": {
              "$ref": "#/$defs/pathSegment"
            },
            "source_project_url": {
              "$ref": "#/$defs/httpsUrl"
            },
            "target_group_path": {
              "$ref": "#/$defs/namespacePath"
            }
          }
        }
      ]
    },
    "projectOverride": {
      "allOf": [
        {
          "$ref": "#/$defs/policy"
        },
        {
          "type": "object",
          "required": [
            "target_project_path"
          ],
          "properties": {
            "target_project_path": {
              "$ref": "#/$defs/projectPath"
            }
          }
        }
      ]
    },
    "projectExclusion": {
      "type": "object",
      "required": [
        "target_project_path",
        "reason"
      ],
      "properties": {
        "target_project_path": {
          "$ref": "#/$defs/projectPath"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
